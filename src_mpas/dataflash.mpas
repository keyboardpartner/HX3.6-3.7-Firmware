// Dataflash: Daten in FPGA-Config-Flash speichern und daraus holen

unit dataflash;

uses twi_systimer, const_def, spi_rw, edit_vals, avrco_compat, 
  intflash, var_def, serial1, lcd_twi;

const 

  // Anzahl benutzter Blöcke, gelten für SAM-Flash und DF:
  c_FPGA_bcount: Word     = $130;  // 304 dez.
  c_firmware_bcount: Word = 128;
  c_preset_bcount: Word   = 128;
  c_midicc_bcount: Word   = 16;
  c_scan_bcount: Word     = 2;     // Länge 2 Blocks
  c_taper_bcount: Word    = 4;     // Länge 4 Blocks
  c_waveset_bcount: Word  = 32;    // Länge 32 (8 x 4 Blocks)

  c_scan_len    = 8192;
  c_fir_len     = 2048;
  c_taper_len   = 4096;
  c_waveset_len = 16384;
  c_ccset_len   = 3200;

procedure DF_protect;
procedure DF_unprotect;

// für SD_ReadBinFile und Parser: Block speichern
procedure DF_EraseWriteBlock(current_block, block_len: Word);

procedure DF_ProcessBlocks(start_block: Word; byte_count : DWord;
                        block_proc: ^TblockProcType);
procedure DF_ReadBlock(block_nr, block_len: Word);

function DF_EraseBlock(block_nr: Word): boolean;
function DF_WriteBlock(block_nr, block_len: word; do_verify: Boolean): boolean;
procedure DF_CopyFromQSPI(dest_block, block_count: Word);

procedure DF_LoadScanDriver;

function DF_CheckDFUDLflags: Boolean;    // Liefert TRUE wenn gültige DFUDL-Flags vorhanden sind
function DF_CheckDFUDLfailsafe: Boolean; // Liefert TRUE wenn Failsafe komplett geladen wurde 
function DF_CheckDFUprefix: Boolean;     // Liefert TRUE wenn gültiges DFU-File
function DF_CopyDFUimageFromSAM(bl_active: Boolean): t_err;  // Liest und interpretiert DFU-Image aus SAM-Flash, führt Update durch, liefert Fehlercode

{$IFDEF BOOTLOADER}
function DF_CopyFirmwareFromFailsafe: t_err; // Liest Firmware aus Failsafe, liefert Fehlercode
function DF_CopyFPGAfromFailsafe: t_err; // Liest FPGA aus Failsafe, liefert Fehlercode
procedure DF_BlocksToIntFlash(start_block: Word; block_count: Word);
{$ELSE}
function DF_getChecksum(df_first_block, df_last_block: Word): Word;
procedure DF_LoadTapering(taper: Word);
procedure DF_LoadWaveset(waveset: Word);
procedure DF_LoadFIRcoeff;
procedure DF_LoadCCarray(cc_set: Word);
{$ENDIF}

procedure DF_StartDFU; // SAM-MCU Reset, Start mit Bootloader
procedure DF_StopDFU(start_dsp: Boolean); // SAM-MCU Reset aufheben wenn start_dsp = TRUE

{$IFDEF DEBUG_DF}
procedure DF_BlockContent_msg(block_len: Word);
{$ENDIF}

procedure DF_Stop_DSP;  // SAM in Reset halten, QSPI Reset, aber nicht freigeben
procedure DF_Start_DSP; // SAM-Reset aufheben, QSPI unterbrochen, DSP bootet
procedure DF_ena_QSPI;  // SAM in Reset halten, QSPI-Verbindung zum S25F512 freischalten

type

  t_DFUDL_rec = record
    Words: array[0..2023] of Word; // Zieladressen (Blocknummer) der enhaltenen Blocks
    Exitflag: DWord;
    ParamCount: DWord;
    Timestamp: DWord;
    PartsBits: DWord;
    ScanFailsafeBcount: DWord;
    FPGAFailsafeBcount: DWord;
    FWFailsafeBcount: DWord;
    FPGAversion: DWord;
    FWversion: DWord;
    Datachecksum: DWord;
    BlockCount: DWord;
    Validflag: DWord;
  end;

  // DFU_element_prefix wird von SAM2DFU.exe
  // vor jedem Datenblock (dann nur noch 2048 Bytes!) eingefügt
  t_DFU_element_prefix = record   // DREAM DFU element prefix, 12 Bytes
    DestAddr: DWord;    // beginnt mit $81E00000, zählt in Words!
    WordCount: Word;    // Anzahl Words bis zum nächsten Prefix, $400
    Offset: Word;       // $000A, keine Ahnung warum
    Fill: DWord;        // immer 0
  end;

var
  DF_FirmwareChecksum: DWord;
  DF_Errors: Word;

  DF_DestBlock: Word;  // für WIFI-Update über Parser
  DF_DestBlockCount: Word;
  
  CurrentQSPIaddr: DWord;
  CurrentQSPIaddrBytes: Array[0..3] of Byte at CurrentQSPIaddr; // Overlay (union)
  CurrentQSPIblock: Word;

  DFUprefix: t_DFU_element_prefix; // aktueller DFU-Block-Prefix, wird von SAM2DFU.exe vor jedem Block eingefügt
  DFUprefixBytes: Array[0..SizeOf(DFUprefix) - 1] of Byte at DFUprefix;
  DownloadIsRawDFU: Boolean;  // wenn DFUDL-Validflag nicht stimmt, aber Prefix-Info da ist, könnte es sich um rohes DFU handeln, dann wird IsRawDFUinBlockBuffer = true gesetzt, damit trotzdem weitergearbeitet werden kann; rohes DFU hat nur den Prefix, aber keine DFUDL-Info, die Zieladresse und Blockanzahl enthält

  ExitBootloaderMenuWhenDone: Boolean;
  UpdateBitFlags: DWord;
  UpdateTimeStamp: DWord;

  DFUDL: t_DFUDL_rec; // DFU Destination List

implementation

const
  s_dfu_1 = '/ Copy QSPI to <dest> <blk>:';
  s_dfu_err = '/ DFU flags failed';

var
  send_str: String[16];
  idx, temp_w: Word; temp_b: Byte;
  df_blk_counter, df_receive: Word;
  ptr_dword : ^dword;
  ptr_word : ^word;
  ptr_byte : ^byte;

  DFaddr: DWord;
  DFaddrBytes: Array[0..3] of Byte at DFaddr;
  
// #############################################################################


procedure DF_StartDFU;
// SAM-MCU Reset in Bootloader
begin
  SAM_NRST:= false;   // SAM-MCU Reset, noch ohne QSPI
  SPI_fpga_send_byte(246, 1); // Set DSP ROW01 bits = 1
  mDelay(1);
  QFL_NRST:= true;
  SAM_NRST:= true;    // SAM-MCU Reset aufheben
  mDelay(100);
end;

procedure DF_StopDFU(start_dsp: Boolean);
begin
  SAM_NRST:= false;   // SAM-MCU Reset
  SPI_fpga_send_byte(246, 0); // Set DSP ROW bits = 0
  mDelay(10);
  // SAM-MCU Reset aufheben wenn start_dsp = TRUE
  SAM_NRST:= start_dsp;
  if start_dsp then
    mDelay(200); // Zeit für DSP-Firmware-Boot
end;

procedure DF_Stop_DSP;
// SAM in Reset halten, QSPI Reset, aber nicht freigeben
// Achtung: FPGA bekommt keinen Sync-Takt vom
// DSP mehr, gelbe LED kann erlöschen
const s_msg = '/ DSP stopped';
begin
  BusAvailable:= false;
  SAM_NRST:= false;  // DSP anhalten
  QFL_NRST:= false;  // FL512 QSPI SAM Flash Reset
  Delay_ms(1);
  QFL_NRST:= true;   // Reset-Impuls für FL512  QSPI SAM Flash
  Serial1_sendstringCRLF(s_msg);
end;

procedure DF_ena_QSPI;
// SAM in Reset halten, QSPI-Verbindung zum S25F512 freischalten
// Achtung: FPGA bekommt keinen Sync-Takt vom
// DSP mehr, gelbe LED kann erlöschen
const s_msg = '/ QSPI enabled';
begin
  DF_Stop_DSP;
  F_QSPI_ENA:= true;   // Select QSPI SAM Flash to MCU
  Serial1_sendstringCRLF(s_msg);
end;

procedure DF_Start_DSP;
// SAM-Reset aufheben, QSPI unterbrochen, DSP bootet
const s_msg = '/ DSP started';
begin
  BusAvailable:= true;
  F_QSPI_ENA:= false;   // Select QSPI SAM Flash = FALSE, normaler Betrieb
  QFL_NRST:= false;  // FL512 QSPI SAM Flash Reset
  Delay_ms(1);
  QFL_NRST:= true;   // Reset-Impuls für FL512  QSPI SAM Flash
  // DF_protect;
  mDelay(1);
{$IFDEF BOOTLOADER}
  SPI_fpga_send_byte(246, 1); // Set DSP ROW01 bits = 1, Bootloader aktiv
{$ELSE}
  SPI_fpga_send_byte(246, 0); // Set DSP ROW01 bits = 0, Bootloader inaktiv
{$ENDIF}
  SAM_NRST:= true;     // DSP Reset aufheben
  mDelay(200);  // DSP bootet
  Serial1_sendstringCRLF(s_msg);
end;

procedure DF_qspi_addr();
begin
  SPI2_Read(CurrentQSPIaddrBytes[3]);   // Adr Bits 31..24
  SPI2_Read(CurrentQSPIaddrBytes[2]);   // Adr Bits 23..16
  SPI2_Read(CurrentQSPIaddrBytes[1]);   // Adr Bits 15..8
  SPI2_Read(CurrentQSPIaddrBytes[0]);   // Adr Bits 7..0
end;

procedure DF_SAM_ReadNextPrefix();
// Lese BlockArray aus SAM-DataFlash, max. 4096 bytes
// Tauscht Word-Bytes wg. SAM5504-Byte-Reihenfolge
var
  byte_idx, word_count: Word;
begin
  byte_idx:= 0;
  F_DS:= false; // hier _CS für FL512 SAM-Flash
  SPI2_Read($0C); // Fast Read Page, 4 Byte Address
  DF_qspi_addr;
  SPI2_Read(0); // Dummy für $0C read mode
  for word_count:= 0 to (SizeOf(DFUprefix) div 2) - 1 do begin
    DFUprefixBytes[byte_idx + 1]:= Byte(SPI2_Read(0));
    DFUprefixBytes[byte_idx]:= Byte(SPI2_Read(0));
    byte_idx:= byte_idx + 2;
    CurrentQSPIaddr:= CurrentQSPIaddr + 2;
  end;
  F_DS:= true;
end;

procedure DF_SAM_ReadNextChunk(var byte_idx: Word; word_count: Word);
// Lese BlockArray aus SAM-DataFlash, max. 4096 bytes
// Tauscht Word-Bytes wg. SAM5504-Byte-Reihenfolge
var
  word_idx: Word;
begin
  F_DS:= false; // hier _CS für FL512 SAM-Flash
  SPI2_Read($0C); // Fast Read Page, 4 Byte Address
  DF_qspi_addr;
  SPI2_Read(0); // Dummy für $0C read mode
  for word_idx:= 0 to word_count - 1 do begin
    BlockBuffer8[byte_idx + 1]:= Byte(SPI2_Read(0));
    BlockBuffer8[byte_idx]:= Byte(SPI2_Read(0));
    byte_idx:= byte_idx + 2;
    CurrentQSPIaddr:= CurrentQSPIaddr + 2;
  end;
  F_DS:= true;
end;

procedure DF_SAM_ReadNextBlock();
// Lese BlockArray aus SAM-DataFlash, max. 4096 bytes
// Tauscht Word-Bytes wg. SAM5504-Byte-Reihenfolge
const s_msg = '/ QSPI read block #';
var
  words_remaining: Integer;
  byte_idx, words_to_read: Word;
begin
  byte_idx:= 0;
  if DownloadIsRawDFU then begin
    words_remaining:= 2048; // 2048 Words pro Block
    repeat
      words_to_read:= DFUprefix.WordCount;
      if words_to_read > words_remaining then
        words_to_read:= words_remaining;
      DF_SAM_ReadNextPrefix();
      DF_SAM_ReadNextChunk(byte_idx, words_to_read);
      words_remaining:= words_remaining - Integer(words_to_read);
    until words_remaining <= 0;
  end else begin
    DF_SAM_ReadNextChunk(byte_idx, 2048);
  end;
{$IFDEF DEBUG_SAM}
  Serial1_sendstringCRLF(s_msg + IntToStrTrim(CurrentQSPIblock));
  DF_BlockContent_msg(4096);
{$ENDIF}
  inc(CurrentQSPIblock);
end;

procedure DF_SAM_ReadFirstBlock(block_nr: Word);
// Lese BlockArray aus SAM-DataFlash, max. 4096 bytes
// Tauscht Word-Bytes wg. SAM5504-Byte-Reihenfolge
const 
  block_len: Word = 4096;
begin
  CurrentQSPIblock:= block_nr;
  CurrentQSPIaddr := DWord(block_nr) * block_len;
  DF_SAM_ReadNextPrefix();
  DownloadIsRawDFU:= (DFUprefix.DestAddr = $81E80000);
  CurrentQSPIaddr := DWord(block_nr) * block_len;
  if not DownloadIsRawDFU then begin
    memset(@DFUprefix, 0, SizeOf(DFUprefix));
    DFUprefix.WordCount:= 2048;
  end;
  DF_SAM_ReadNextBlock();
end;


function DF_CheckDFUprefix: Boolean;
// Liefert TRUE wenn gültiges DFU-File
begin
  // Überprüfen, ob Prefix-Info gültig ist, falls versehentlich
  // DSP-DFU oder Soundbank geladen wurde
  result:= (DFUprefix.WordCount = $400) and
           (DFUprefix.DestAddr >= $81E00000) and
           (DFUprefix.DestAddr < $82000000);
end;

function DF_CheckDFUDLflags: Boolean;
// Liefert TRUE wenn gültige DFUDL-Flags vorhanden sind
begin
  result:= (DFUDL.Validflag = $55AA) and
           (DFUDL.BlockCount < 2000) and
           (DFUDL.BlockCount > 0);
end;

function DF_CheckDFUDLfailsafe: Boolean;
// Liefert TRUE wenn Failsafe komplett geladen wurde
begin
  result:= (DFUDL.Words[0] = c_dfudl_failsafe_DF or $9000)    // $9278
       and (DFUDL.FWFailsafeBcount > 0)
       and (DFUDL.FPGAFailsafeBcount > 0)
       and (DFUDL.ScanFailsafeBcount > 0);
end;

function DF_is_block_programmed(block_nr: Word): Boolean;
// Überprüft Block, liefert FALSE wenn unprogrammiert (alles $FF)
var buf_sum: DWord;
begin
  DF_ReadBlock(block_nr, 4096);
  buf_sum:= 0;
  for idx:= 0 to 4095 do
    buf_sum:= buf_sum + DWord(BlockBuffer8[idx]);
  result:= buf_sum < $FF000;
end;

