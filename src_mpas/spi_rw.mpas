procedure SPI_xc_requestEditArray;
begin
{$IFDEF DEBUG_SPI_XC}
  Serial1_sendstringCRLF('/ XC Req EditArray');
{$ENDIF}
  SPI_xc_writeram(1, c_xreq_edit_arr);
end;

procedure SPI_xc_requestExtdArray;
// Fordere extendedArray von ESP32 an
begin
{$IFDEF DEBUG_SPI_XC}
  Serial1_sendstringCRLF('/ XC Req ExtdArray');
{$ENDIF}
  SPI_xc_writeram(1, c_xreq_extd_arr);
end;

// --------------------------------------------------------------------------------


procedure SPI_dump_xchgbuf(start_addr, len: Word);
var count: Word;
  hexstr: String[4];
begin
  if len > 2042 then  // 4 Bytes f�r Flag und L�nge!
    len:= 2042;
  F_RS:= false;  // Register Select Pin
  delay_us(1);
  SPI2_Read(c_xcmd_xchng_read); // Kommando für XCHGBUF, siehe FPGA-Design qspi_connect.vhd
  for count := 0 to 2047 do
    BlockBuffer8[count]:= SPI2_Read(0); // Datenbyte, Write nicht benutzt
  F_RS:= true;  // Register Select Pin
  SPI_dump_buf(start_addr, len);
end;

// --------------------------------------------------------------------------------

procedure SPI_xc_interpret_data;
// BRAM und Header wurden bereits gelesen und
// Binary Parser Commands im Parser behandelt
var
  command: Word;
begin
  command:= SPI_xc_header.mflag and $00FF;
  case command of
  (c_xreq_edit_arr): 
    begin
      // EditArray angefordert
      {$IFDEF DEBUG_SPI_XC}
        Serial1_sendstringCRLF('/ XC EDIT_ARR requested');
      {$ENDIF}
      memcpy(@BlockBuffer8, @edit_array, 512); // 512 Bytes
      SPI_xc_writeram(512, c_xmsg_edit_arr); // EditArray in FPGA-Exchange-RAM schreiben
      SPI_xc_wait_ack(100); // Warte, bis ESP das editArray abgeholt hat
    end;
  (c_xreq_extd_arr):
    begin
      // ExtdArray angefordert
      {$IFDEF DEBUG_SPI_XC}
        Serial1_sendstringCRLF('/ XC EXTD_ARR requested');
      {$ENDIF}
      memcpy(@BlockBuffer8, @eep_ExtendedBoardInits, 1536);  // 1536 Bytes
      SPI_xc_writeram(1536, c_xmsg_extd_arr); // ExtdArray in FPGA-Exchange-RAM schreiben
      SPI_xc_wait_ack(100); // Warte, bis ESP das extdArray abgeholt hat
    end;
  (c_xmsg_edit_arr):
    begin
      // EditArray von ESP32 empfangen, in edit_array kopieren
      {$IFDEF DEBUG_SPI_XC}
        Serial1_sendstringCRLF('/ XC EDIT_ARR received');
      {$ENDIF}
      // memcpy(@edit_array, @BlockBuffer8, 512); // 512 Bytes
      {$IFDEF DEBUG_SPI_XC}
        SPI_dump_buf(0, 64);
      {$ENDIF}
    end;
  (c_xmsg_extd_arr):
    begin
      // ExtdArray von ESP32 empfangen, in eep_ExtendedBoardInits kopieren
      {$IFDEF DEBUG_SPI_XC}
        Serial1_sendstringCRLF('/ XC EXTD_ARR received');
      {$ENDIF}
      // memcpy(@eep_ExtendedBoardInits, @BlockBuffer8, 1536);  // 1536 Bytes
      {$IFDEF DEBUG_SPI_XC}
        SPI_dump_buf(0, 64);
      {$ENDIF}
    end;
  end;
end;


{$ENDIF}    // NOT Bootloader
end.