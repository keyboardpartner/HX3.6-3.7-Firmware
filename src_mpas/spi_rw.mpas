//    ########  #### ##    ##        ######  ##     ## ########  
//
// ################################################################################


procedure SPI_xc_send_singlebinarycmd(param: Word; value: Word);
begin
  BlockBuffer16[0]:= param;  // Parameter-Nummer 1000..9999
  BlockBuffer16[1]:= value;  // Wert
  SPI_xc_writeram(4, c_xmsg_binary_cmd);  // Anzahl der Datenbytes = 2 Worte = 4
  SPI_xc_wait_ack(100); // Warte, bis ESP die Message abgeholt hat
end;

