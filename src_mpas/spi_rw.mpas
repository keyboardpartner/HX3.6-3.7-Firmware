{$IFNDEF BOOTLOADER}

// RS-Commands, neues QSPI-Connect f�r ESP32

function SPI_xc_setcmd(reg: Byte): Byte;
begin
  F_RS:= false;            // Register Select Pin
  result:= SPI2_Read(reg);
  F_RS:= true;
end;

function SPI_xc_getstatus(): Byte;
begin
  F_RS:= false;            // Register Select Pin
  result:= SPI2_Read(c_xcmd_status_read);
  F_RS:= true;
end;

function SPI_xc_wait_ack(timeout: Word): boolean;
const s_timeout = '/ XC Status Timeout ERR';
begin
  result:= true;
  while ((SPI_xc_getstatus() and c_xsta_ack_by_receiver_mask) = 0) do begin
    mdelay(1);
    dec(timeout);
    if timeout = 0 then begin
      Serial1_sendstringCRLF(s_timeout);
      result:= false;
      break;
    end;
  end;
end;

function SPI_xc_wait_data(timeout: Word): boolean;
const s_timeout = '/ XC Status Timeout ERR';
begin
  result:= true;
  while ((SPI_xc_getstatus() and c_xsta_rxbuf_got_data_mask) = 0) do begin
    mdelay(1);
    dec(timeout);
    if timeout = 0 then begin
      Serial1_sendstringCRLF(s_timeout);
      result:= false;
      break;
    end;
  end;
end;

// ################################################################################


procedure SPI_dump_buf(start_addr, len: Word);
var count: Word;
  hexstr: String[4];
begin
  Serial1_sendstring('MFlag: 0x');
  WordToHex(SPI_xc_header.mflag, hexstr);
  Serial1_sendstring(hexstr);
  Serial1_sendstring(', MsgLen: 0x');
  WordToHex(SPI_xc_header.len, hexstr);
  Serial1_sendstring(hexstr);
  Serial1_sendstring(', ChkSum: 0x');
  WordToHex(SPI_xc_header.chksum, hexstr);
  Serial1_sendstring(hexstr);
  start_addr:= (start_addr div 16) * 16;
  // liest len Bytes aus Exchange-RAM des FPGA und gibt sie im seriellen Monitor aus
  for count := start_addr to start_addr + len - 1 do begin
    if (count mod 16 = 0) then begin
      Serial1_CRLF;
      WordToHex(count, hexstr);
      Serial1_sendstring(hexstr);
      Serial1_sendstring(': ');
    end;
    ByteToHex(BlockBuffer8[count], hexstr);
    Serial1_sendstring(hexstr);
    Serial1_sendchar(#32);
  end;
  Serial1_CRLF;
end;


function SPI_xc_readram(): boolean;
// schreibt bis zu 2KBytes in Exchange-RAM des FPGA, 
// benötigt hierfür etwa 4 ms
// liefert TRUE wenn erfolgreich
const s_flag_err = '/ XC Flag ERR';
var count: Word;
begin
  F_RS:= false;  // Register Select Pin
  SPI2_Read(c_xcmd_xchng_read); // Kommando für XCHGBUF, siehe FPGA-Design qspi_connect.vhd
  result:= true;
  for count := 0 to 5 do
    SPI_xc_header_bytes[count]:= SPI2_Read(0); // Datenbyte, Write nicht benutzt
  // Magic Flag und L�nge sind jetzt bekannt
  if (SPI_xc_header.mflag and $FF00) <> $5A00 then begin
    F_RS:= true;  // Register Select Pin
    Serial1_sendstringCRLF(s_flag_err);
    result:= false;
    exit;
  end;
  if SPI_xc_header.len > 2042 then  // 4 Bytes f�r Flag und L�nge!
    SPI_xc_header.len:= 2042;
  for count := 0 to SPI_xc_header.len - 1 do
    BlockBuffer8[count]:= SPI2_Read(0); // Datenbyte, Write nicht benutzt
  F_RS:= true;  // Register Select Pin
  SPI_xc_setcmd(c_xcmd_ack_by_receiver);
end;

procedure SPI_xc_writeram(len: Word; msg_type: Word);
// schreibt bis zu 2KBytes in Exchange-RAM des FPGA,
// benötigt hierfür etwa 4 ms
var count: Word;
begin
  if len > 2042 then  // 6 Bytes für Header
    len:= 2042;
  SPI_xc_header.mflag:= $5A00 or msg_type;
  SPI_xc_header.len:= len;
  SPI_xc_header.chksum:= 0; // Checksumme optional, derzeit nicht benutzt

  F_RS:= false;  // Register Select Pin 
  SPI2_Read(c_xcmd_xchng_write); // Kommando für XCHGBUF, siehe FPGA-Design qspi_connect.vhd
  for count := 0 to 5 do
    SPI2_Read(SPI_xc_header_bytes[count]); // Datenbyte, Write nicht benutzt
  for count := 0 to len - 1 do
    SPI2_Read(BlockBuffer8[count]); // Datenbyte, Lese-Ergebnis nicht benutzt
  F_RS:= true;  // Register Select Pin
end;

